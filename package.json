    "dotenv": "^17.4.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.7.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
