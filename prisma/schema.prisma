generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int       @id @default(autoincrement())
  name            String
  email           String    @unique
  password        String
  role            UserRole
  roles           String[]  @default([])
  active          Boolean   @default(true)
  // ── MFA (TOTP, RFC 6238) ──
  // mfaSecret is the raw base32 TOTP seed; it's only meaningful inside the DB
  // boundary (encryption-at-rest is the protection layer per the HIPAA scorecard).
  // mfaBackupCodes stores SHA-256 hex hashes of one-time recovery codes — never
  // the codes themselves — so a DB compromise can't unlock anyone's MFA.
  mfaEnabled      Boolean   @default(false)
  mfaSecret       String?
  mfaBackupCodes  String[]  @default([])
  mfaEnrolledAt   DateTime?
  // Set true when an admin provisions or resets an account with a shared
  // default password — the (admin) layout redirects to /change-password
  // until the user picks their own. Cleared on successful change.
  mustChangePassword Boolean @default(false)
  createdTickets  Ticket[]  @relation("CreatedBy")
  assignedTickets Ticket[]  @relation("AssignedTo")
  csrOrders       Order[]   @relation("OrderCsr")
  driverItems     OrderItem[] @relation("OrderItemDriver")
  intakeOrders    Order[]   @relation("OrderIntakeBy")
  uploadedAttachments OrderAttachment[] @relation("OrderAttachmentUploadedBy")
}

// `driver` replaced `dispatcher` per Brent's call (2026-06). Phase 1A's
// backfill renamed every existing user row; commit B drops the legacy value.
enum UserRole {
  supplier
  driver
  csr
}

model Facility {
  id       Int      @id @default(autoincrement())
  name     String
  initials String   @default("")
  active   Boolean  @default(true)
  address  String   @default("")
  city     String   @default("")
  state    String   @default("MI")
  zip      String   @default("")
  phone    String?
  contact  String?
  facilityType String? // SNF | ALF | PhysicianGroup | HomeHealth | Hospital | Other (open question for client)
  tickets  Ticket[]
  orders   Order[]
}

model Ticket {
  id             String        @id @default(cuid())
  facilityId     Int
  facility       Facility      @relation(fields: [facilityId], references: [id])
  patientName    String
  room           String
  product        String
  serialNumber   String        @default("")
  orderType      OrderType     @default(rent)
  orderedBy      String
  orderedByEmail String        @default("")
  orderTime      DateTime      @default(now())
  notes          String        @default("")
  status         OrderStatus   @default(NEW)
  source         TicketSource  @default(internal)
  createdById    Int?
  createdBy      User?         @relation("CreatedBy", fields: [createdById], references: [id])
  driverId       Int?
  driver         User?         @relation("AssignedTo", fields: [driverId], references: [id])
  assignedAt     DateTime?
  inTransitAt    DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime      @default(now())
  auditEntries   TicketAudit[]
}

enum OrderStatus {
  NEW
  ASSIGNED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum OrderType {
  rent
  buy
}

enum TicketSource {
  internal
  external
}

model TicketAudit {
  id       String   @id @default(cuid())
  ticketId String
  ticket   Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ts       DateTime @default(now())
  who      String
  action   String
}

// Serial numbers track physical units of equipment. Each serial belongs to
// one Equipment definition (the "what") and carries its own status / location /
// linked Order (the "where"). The legacy InventoryItem model was a dead
// duplicate of Equipment and has been removed; serials now reference Equipment
// directly so par-level math and stock counts live on one canonical row.
model SerialItem {
  id          String        @id @default(cuid())
  equipmentId String
  // Restrict on Equipment delete — physical units shouldn't silently vanish
  // when an equipment SKU is removed; force the supplier to reassign or
  // retire the serials first. The legacy InventoryItem→SerialItem relation
  // was Cascade, which is unsafe now that serials are the source of truth
  // for inventory counts. Made explicit (not relying on Prisma's default).
  equipment   Equipment     @relation(fields: [equipmentId], references: [id], onDelete: Restrict)
  sn          String        @unique
  status      SerialStatus  @default(available)
  location    String        @default("Warehouse")
  notes       String        @default("")
  // orderId is set when this physical unit is deployed on an order. Manually
  // assigned by warehouse staff from the inventory screen; cleared on return.
  orderId     String?
  order       Order?        @relation(fields: [orderId], references: [id])
  deployedAt  DateTime?
  retiredAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([equipmentId, status])
  @@index([orderId])
  @@index([status])
}

enum SerialStatus {
  available
  deployed
  in_service
  out_of_service
  retired
}

// Documents attached to an order — intake forms, signed delivery tickets,
// insurance correspondence. Bytes stored in-DB (bytea) so they ride the same
// backup/encryption pipeline as PHI; sized cap is enforced at the API layer.
model OrderAttachment {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  filename     String
  mimeType     String
  size         Int
  data         Bytes
  uploadedById Int?
  uploadedBy   User?    @relation("OrderAttachmentUploadedBy", fields: [uploadedById], references: [id])
  uploadedAt   DateTime @default(now())

  @@index([orderId])
}

model AuditEntry {
  id      String   @id @default(cuid())
  ts      DateTime @default(now())
  who     String
  role    String
  action  String
  detail  String
  ref     String
  // Patient name captured at the moment the audit entry was written. Empty
  // for non-order events (login, MFA, password change). Denormalized so the
  // audit log stays a single-table lookup even if the order is later
  // renamed or its patient details edited.
  patient String   @default("")
}

// ─── Revamp models (additive) ─────────────────────────────────────────────────

// Stage = where the order is in the lifecycle. Status is DERIVED from
// timestamps + populated fields, never picked manually.
// ELDERCARE folded into the eldercare boolean per Brent (2026-06); the
// Phase 1A backfill migrated SERVICE_PICKUP → PICK_UP. Commit B drops both.
enum WorkOrderType {
  DELIVERY
  SERVICE_CALL
  PICK_UP
  EQUIPMENT_MOVE
  EXCHANGE
  FACILITY_DELIVERY
}

enum OrderStage {
  INTAKE_OFF_RIP        // 1a — 5 fields captured, awaiting verification
  INTAKE_VERIFICATION   // 1b — gathering missing info / auth
  READY_TO_ASSIGN       // 2  — all required info present, awaiting dispatcher
  ASSIGNED              // 3  — dispatcher assigned + ticket printed
  ACKNOWLEDGED          // 4  — dispatcher acknowledged the assignment
  OUT_FOR_DELIVERY      // 5  — dispatcher en route
  DOOR_TAG              // 5b — attempted, no one home; awaiting re-attempt
  DELIVERED             // 6  — confirmed delivered
  CANCELLED             // terminal (kill switch)
}

enum AuthStatus {
  NOT_REQ
  REQUIRED
  READY_TO_SUBMIT
  PENDING_SIGNATURE
  // PENDING_DOCUMENTS replaces the legacy multi-step "pending" states per
  // Brent's call. When selected, the UI reveals Order.pendingDocuments
  // (multi-select of DIAGNOSIS_CODE / SIGNATURE / FACE_SHEET / PICKUP_TICKET
  // / NOTES). PENDING_SIGNATURE backfills into this value.
  PENDING_DOCUMENTS
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  DENIED
}

// Brent-stage manual outcome for the Verification step — not derived. Distinct
// from OrderStage (lifecycle) and OutcomeStatus (overall lifecycle outcome).
enum VerificationStatus {
  READY_FOR_DELIVERY
  ON_HOLD
  TRANSFERRED
}

// Brent 2026-06 commit B: DataEntryStatus / BillingStatus / PlanType enums
// removed alongside their Order columns.

enum DeductibleStatus {
  MET
  NOT_MET
  NA
}

enum HandlerType {
  INTERNAL
  REP
  FACILITY
}

// Brent 2026-06 follow-up: the "Delivery Status" picker shows TBD (ACTIVE),
// On Hold, Out for Delivery, Door Tag, Cancelled, Delivered. OUT_FOR_DELIVERY
// + DOOR_TAG are added here as picker-selectable. The legacy LOOSE_ENDS /
// TRANSFERRED / REJECTED / WRITE_OFF values are kept for back-compat on any
// existing row that still uses them, but the picker filters them out.
enum OutcomeStatus {
  ACTIVE
  READY_TO_SCHEDULE
  SCHEDULED
  ON_HOLD
  HELD_FOR_AUTH
  OUT_FOR_DELIVERY
  DOOR_TAG
  LOOSE_ENDS
  TRANSFERRED
  REJECTED
  CANCELLED
  DELIVERED
  WRITE_OFF
}

model Order {
  id              String      @id @default(cuid())
  // Display handle: ED-{yyyy}-{6-digit seq}, generated server-side
  orderNumber     String      @unique
  stage           OrderStage  @default(INTAKE_OFF_RIP)
  workOrderType   WorkOrderType @default(DELIVERY)
  linkedOrderId   String?
  linkedOrder     Order?      @relation("OrderLink", fields: [linkedOrderId], references: [id])
  linkedOrders    Order[]     @relation("OrderLink")

  // ── 1a Off-Rip Intake (5 fields) ──
  csrId           Int?
  csr             User?       @relation("OrderCsr", fields: [csrId], references: [id])
  patientFirst    String      @default("")
  patientLast     String      @default("")
  facilityId      Int?
  facility        Facility?   @relation(fields: [facilityId], references: [id])
  // Order.whatsNeeded String[] removed 2026-06 — superseded by
  // Order.pendingDocuments below (hardcoded 5-key PENDING_DOCUMENT_OPTIONS).

  // ── 1b Verification ──
  primaryInsuranceKey   String?  // FK by key into InsuranceOption
  secondaryInsuranceKey String?
  deductibleStatus      DeductibleStatus?
  coinsurancePct        Int?              // patient coinsurance share, whole percent (e.g. 20, 35)
  deductibleAmount      Decimal?  @db.Decimal(10, 2)  // patient deductible owed, dollars
  // Brent 2026-06 commit B: planMemberId / planName / planType / dataEntryStatus
  // / billingStatus removed — replaced by the simpler verification flow.
  authStatus            AuthStatus  @default(NOT_REQ)
  authRequiredAt        DateTime?
  authSubmittedAt       DateTime?
  authApprovedAt        DateTime?
  authDeniedAt          DateTime?
  dosSubmitted          DateTime?

  fulfillmentCompanies  String[] @default([]) // multi-select keys (real fulfillment companies only)
  status                OutcomeStatus @default(ACTIVE) // outcome state — ACTIVE | ON_HOLD | TRANSFERRED | REJECTED | CANCELLED | DELIVERED | WRITE_OFF
  handler               HandlerType? // future split

  // Verification-step manual outcome per Brent (2026-06). Independent of the
  // automatic OrderStage derivation.
  verificationStatus    VerificationStatus?
  // Eldercare flag replaces the ELDERCARE work-order type — the type is now
  // independent of the eldercare nature of the order.
  eldercare             Boolean @default(false)
  // Multi-select that's only meaningful when authStatus = PENDING_DOCUMENTS.
  // Stored as string keys (DIAGNOSIS_CODE / SIGNATURE / FACE_SHEET /
  // PICKUP_TICKET / NOTES) — code-locked enum, no separate lookup table.
  pendingDocuments      String[] @default([])

  // ── Dates ──
  callReceivedDate      DateTime?
  dischargeDate         DateTime? // DC Date — most workflow-critical
  requestedDeliveryDate DateTime? // Facility/family requested target — drives dispatcher routing
  // Order Date = createdAt (auto-stamped, never user-entered)

  // ── Stage 2/3/4/5 ──
  // Brent 2026-06 commit B: dispatcherId / dispatcher relation / deliveredAt
  // dropped — per-item driver + completedAt on OrderItem replace them.
  printedAt       DateTime?
  acknowledgedAt  DateTime?
  outForDeliveryAt DateTime?
  doorTaggedAt    DateTime?
  cancelledAt     DateTime?
  cancellationReason String?

  // Item Type derived from Equipment categories — no field stored.
  // Equipment + accessories live in OrderItem.

  notes           String      @default("")
  createdById     Int?
  createdBy       User?       @relation("OrderIntakeBy", fields: [createdById], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items           OrderItem[]
  history         OrderEvent[]
  serials         SerialItem[]
  attachments     OrderAttachment[]

  @@index([stage])
  @@index([csrId])
  @@index([dischargeDate])
  @@index([workOrderType])
  @@index([linkedOrderId])
}

model OrderItem {
  id          String    @id @default(cuid())
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])
  quantity    Int       @default(1)

  // Per-item driver + completion date — replaces order-level dispatcherId /
  // deliveredAt per Brent (2026-06). One order can now have multiple drivers
  // and multiple completion dates (e.g. "Steve delivers beds today; Brent
  // delivers chairs tomorrow"). Backfill copies the order-level values onto
  // every item in prisma/backfills/.
  driverId    Int?
  driver      User?     @relation("OrderItemDriver", fields: [driverId], references: [id])
  // Per-item scheduled delivery date — Brent 2026-06: drives the
  // Delivery Status auto-promotion ladder (every item with driver +
  // scheduledDeliveryDate set ⇒ Order.status = SCHEDULED).
  scheduledDeliveryDate DateTime?
  completedAt DateTime?
  // Per-item Equipment Delivery Status — independent of Order.status
  // (renamed "Full Order Delivery Status" in the UI). Lets a CSR park
  // one item (e.g. a backordered wheelchair) while the rest of the
  // order keeps shipping. Same OutcomeStatus enum so the picker /
  // colors / labels reuse without forking a parallel enum.
  deliveryStatus OutcomeStatus @default(ACTIVE)

  // Per-item door-tag count. One delivery attempt that left a door tag for
  // this specific item increments the counter; multiple drivers / multiple
  // items on the same order can each carry an independent count. Replaces
  // the order-level Door Tag button — Brent 2026-06 follow-up.
  doorTagCount Int @default(0)

  @@index([driverId])
  @@index([completedAt])
}

model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ts        DateTime @default(now())
  who       String
  action    String
  detail    String   @default("")
}

enum EquipmentKind {
  item
  accessory
}

model Equipment {
  id           String        @id @default(cuid())
  category     String        // Wheelchair | Walker/Mobility | Bed | Bath/Commode | Respiratory | Lift | Misc
  name         String        // Human-readable label (e.g., "Hospital Bed")
  abbreviation String        @default("") // e.g., "HSB"
  hcpcsCode    String        @default("") // e.g., "K0001"
  kind         EquipmentKind @default(item)
  active       Boolean       @default(true)
  sortOrder    Int           @default(0)
  color        String?
  parLevel     Int?          // Minimum on-hand stock level (from client par sheet)
  orderItems   OrderItem[]
  serials      SerialItem[]

  @@index([category, active])
  @@index([kind, active])
}

// Generic admin-managed lookup tables. Same shape (key/label/active/sortOrder/color)
// per locked-in pattern across Insurance, Fulfillment Companies, Cancellation Reasons.
// WhatsNeededOption + ItemTypeOption removed 2026-06 — both backed UI surfaces
// that were retired in the Brent rework; nothing reads either table now.

model InsuranceOption {
  id           String  @id @default(cuid())
  key          String  @unique // immutable
  label        String
  coverageType String? // future split: Medicare|Medicaid|Commercial|Auto|WorkersComp|VA|PrivatePay|Other
  planVariant  String? // future split: HMO|PPO|Advantage|...
  accepted     Boolean @default(true)
  color        String?
  sortOrder    Int     @default(0)
  active       Boolean @default(true)
}

model FulfillmentCompany {
  id        String  @id @default(cuid())
  key       String  @unique
  label     String
  color     String?
  sortOrder Int     @default(0)
  active    Boolean @default(true)
}

model CancellationReason {
  id        String  @id @default(cuid())
  key       String  @unique
  label     String
  sortOrder Int     @default(0)
  active    Boolean @default(true)
}

model OrderSequence {
  year    Int @id
  lastSeq Int @default(0)
}

model LoginAttempt {
  emailKey    String    @id
  count       Int       @default(0)
  lockedUntil DateTime?
  updatedAt   DateTime  @updatedAt
}
